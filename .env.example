# ============================================================
# MDT 医疗多智能体协同 RAG 系统 - 环境变量配置
# ============================================================
# 使用方式: 复制本文件为 .env 并填入实际值
#   cp .env.example .env
#
# 优先级: 环境变量 > config/custom.yaml > config/default.yaml
# ============================================================

# ---- LLM 配置 (必填) ----
MDT_LLM_API_KEY=                                     # API 密钥，必填！
MDT_LLM_BASE_URL=https://api.deepseek.com   # OpenAI 兼容 API 地址
MDT_LLM_MODEL=deepseek-chat                  # 模型名称

# ---- Milvus 向量数据库 ----
MDT_USE_MILVUS=true                         # 是否启用 Milvus（true/false）
MDT_MILVUS_URI=http://localhost:19530        # Milvus 连接地址

# ---- 外部服务 ----
MDT_NER_SERVICE_URL=                         # NER 服务地址（BERT-CRF）
MDT_RERANK_API_URL=                          # Reranker API 地址（BGE-Reranker）

# ---- 服务器 ----
MDT_HOST=0.0.0.0                             # 监听地址
MDT_PORT=8000                                # 监听端口